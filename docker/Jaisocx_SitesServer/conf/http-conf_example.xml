<conf>
  <conf-idm path="/usr/lib/jaisocx-http/apps/congratulations/conf/idm-conf.xml" />
  <conf-http>
    <servers>

      <server port="9445" alternative-port="9444" secure="true">

        <domain
            name="cdn.basetasks.site"
            comment="published the cdn of the Jaisocx Sites Tools: workspace/ts/Jaisocx_SitesTools/cdn"
            jks-path="/usr/lib/jaisocx-http/https_keys/2026_2027_basetasks_site.jks"
            jks-alias="basetasks.site"
            jks-passphrase="72vNSMvK3YdgphVwUA34DgrbApK9DgDM4koDA42AK7VmYYaAckivmvhMogCPPXh"
            publish-charset="UTF-8" src-charset="UTF-8">

          <alias
              art="folder"
              url="/"
              path="/opt/jaisocx/sites_tools/workspace/ts/cdn/"
              cache="update"
              list="true"
              each-folder-content-file-name="root.html" />

        </domain>

        <domain
            name="local.basetasks.site"
            jks-path="/usr/lib/jaisocx-http/https_keys/2026_2027_basetasks_site.jks"
            jks-alias="basetasks.site"
            jks-passphrase="72vNSMvK3YdgphVwUA34DgrbApK9DgDM4koDA42AK7VmYYaAckivmvhMogCPPXh"
            document-root="/opt/jaisocx/sites_tools/workspace/php"
            publish-charset="UTF-8" src-charset="UTF-8">

          <alias comment="typescript code"
                 art="folder"
                 url="/"
                 path="/opt/jaisocx/sites_tools/workspace/ts/Jaisocx_SitesTools/"
                 cache="update"
                 list="true"
                 each-folder-content-file-name="root.html" />

          <alias comment="typescript code"
                 art="folder"
                 url="/jaisocx/"
                 path="/opt/jaisocx/sites_tools/workspace/ts/Jaisocx_SitesTools/cdn/node_cdn_installs/node_modules/@jaisocx/"
                 cache="cache"
                 list="true"
                 each-folder-content-file-name="root.html" />

          <alias comment="php code"
                 art="folder"
                 url="/php/"
                 path="/opt/jaisocx/sites_tools/workspace/php/"
                 cache="update"
                 list="true"
                 each-folder-content-file-name="index.php" />

          <alias
              art="folder"
              url="/cdn/fonts/Press_Start_2P/"
              path="/opt/jaisocx/sites_tools/workspace/ts/cdn/fonts/Press_Start_2P/"
              cache="cache"
              list="true"
              each-folder-content-file-name="index.html" />

        </domain>

      </server>

    </servers>

  </conf-http>

</conf>


